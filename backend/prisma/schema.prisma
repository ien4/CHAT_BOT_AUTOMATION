generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  tenantId     String?  @map("tenant_id")

  @@map("admin_users")
}

model LlmProvider {
  id              String   @id @default(uuid())
  name            String
  apiKeyEncrypted String   @map("api_key_encrypted")
  modelName       String   @map("model_name")
  baseUrl         String?  @map("base_url")
  maxTokens       Int      @default(2048) @map("max_tokens")
  temperature     Float    @default(0.7)
  isEnabled       Boolean  @default(true) @map("is_enabled")
  priority        Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("llm_providers")
}

model KnowledgeBase {
  id         String                 @id @default(uuid())
  title      String
  content    String
  category   String
  sourceType String                 @default("manual") @map("source_type")
  sourceUrl  String?                @map("source_url")
  embedding  Unsupported("vector")?
  isActive   Boolean                @default(true) @map("is_active")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")
  fileUrl    String?                @map("file_url")
  parentId   String?                @map("parent_id")
  tags       String[]
  type       String                 @default("document")
  tenantId   String?                @map("tenant_id")
  parent     KnowledgeBase?         @relation("KnowledgeRelation", fields: [parentId], references: [id])
  children   KnowledgeBase[]        @relation("KnowledgeRelation")

  @@index([tenantId])
  @@map("knowledge_base")
}

model PromptTemplate {
  id                 String   @id @default(uuid())
  name               String
  intentType         String   @map("intent_type")
  systemPrompt       String   @map("system_prompt")
  userPromptTemplate String   @map("user_prompt_template")
  modelPreference    String?  @map("model_preference")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  layer              String   @default("intent")
  tenantId           String?  @map("tenant_id")

  @@index([tenantId])
  @@map("prompt_templates")
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  assets      Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("campaigns")
}

model Conversation {
  id                    String        @id @default(uuid())
  fbUserId              String        @map("fb_user_id")
  fbUserName            String?       @map("fb_user_name")
  status                String        @default("active")
  context               Json?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  assignedStaffId       String?       @map("assigned_staff_id")
  handoffStatus         String        @default("bot") @map("handoff_status")
  humanSessionExpiresAt DateTime?     @map("human_session_expires_at")
  channel               String        @default("unknown")
  pageContext           Json?         @map("page_context")
  assignedTenantStaffId String?       @map("assigned_tenant_staff_id")
  tenantId              String?       @map("tenant_id")
  chatwootConversationId String?      @map("chatwoot_conversation_id")
  botGraceUntil         DateTime?     @map("bot_grace_until")
  appointments          Appointment[]
  assignedStaff         Staff?        @relation(fields: [assignedStaffId], references: [id])
  assignedTenantStaff   TenantStaff?  @relation("TenantStaffAssignments", fields: [assignedTenantStaffId], references: [id])
  messages              Message[]

  @@index([fbUserId, tenantId])
  @@index([tenantId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  direction      String
  content        String
  intent         String?
  confidence     Float?
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Appointment {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  fbUserId       String       @map("fb_user_id")
  fbUserName     String?      @map("fb_user_name")
  date           String?
  time           String?
  phone          String?
  email          String?
  notes          String?
  status         String       @default("pending")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  tenantId       String?      @map("tenant_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([tenantId])
  @@map("appointments")
}

model Staff {
  id             String         @id @default(uuid())
  name           String
  telegramId     String         @unique @map("telegram_id")
  telegramChatId String         @unique @map("telegram_chat_id")
  isActive       Boolean        @default(true) @map("is_active")
  isOnDuty       Boolean        @default(false) @map("is_on_duty")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  conversations  Conversation[]

  @@map("staff")
}

model HandoffSetting {
  id                     String   @id @default("singleton")
  pendingTimeoutSeconds  Int      @default(30) @map("pending_timeout_seconds")
  sessionTimeoutSeconds  Int      @default(30) @map("session_timeout_seconds")
  offHoursPendingTimeout Int      @default(10) @map("off_hours_pending_timeout")
  workHoursStart         Int?     @map("work_hours_start")
  workHoursEnd           Int?     @map("work_hours_end")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("handoff_settings")
}

model ContentPackage {
  id          String               @id @default(uuid())
  name        String
  description String?
  coverUrl    String?              @map("cover_url")
  isActive    Boolean              @default(true) @map("is_active")
  isPublic    Boolean              @default(true) @map("is_public")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  tenantId    String?              @map("tenant_id")
  items       ContentPackageItem[]

  @@index([tenantId])
  @@map("content_packages")
}

model ContentPackageItem {
  id          String         @id @default(uuid())
  packageId   String         @map("package_id")
  type        String
  title       String
  content     String?
  url         String?
  fileUrl     String?        @map("file_url")
  description String?
  tags        String[]
  order       Int            @default(0)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  package     ContentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("content_package_items")
}

model QuickReplyMenu {
  id         String   @id @default(uuid())
  intentType String   @map("intent_type")
  pageId     String?  @map("page_id")
  items      Json     @default("[]")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  tenantId   String?  @map("tenant_id")

  @@unique([intentType, pageId])
  @@index([tenantId])
  @@map("quick_reply_menus")
}

model FacebookPage {
  id              String   @id @default(uuid())
  pageId          String   @unique @map("page_id")
  pageName        String   @map("page_name")
  accessToken     String   @map("access_token")
  isActive        Boolean  @default(true) @map("is_active")
  botPersona      String?  @map("bot_persona")
  knowledgeFilter String[] @map("knowledge_filter")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("facebook_pages")
}

model TelegramDestination {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("group")
  purpose   String   @default("status")
  chatId    String   @unique @map("chat_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([purpose, isActive])
  @@map("telegram_destinations")
}

model ChannelConfig {
  id                 String   @id @default(uuid())
  inboxId            String   @unique @map("inbox_id")
  channelType        String   @map("channel_type")
  name               String
  knowledgeFilter    String[] @map("knowledge_filter")
  botPersonaOverride String?  @map("bot_persona_override")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("channel_configs")
}

model Tenant {
  id                     String                @id @default(uuid())
  slug                   String                @unique
  name                   String
  isActive               Boolean               @default(true) @map("is_active")
  chatwootModel          String                @default("dedicated") @map("chatwoot_model")
  chatwootAccountId      String                @map("chatwoot_account_id")
  chatwootBaseUrl        String?               @map("chatwoot_base_url")
  chatwootApiTokenEnc    String?               @map("chatwoot_api_token_enc")
  chatwootTeamId         String?               @map("chatwoot_team_id")
  webhookSecretEnc       String?               @map("webhook_secret_enc")
  telegramGroupChatId    String?               @map("telegram_group_chat_id")
  pendingTimeoutSeconds  Int                   @default(30) @map("pending_timeout_seconds")
  sessionTimeoutSeconds  Int                   @default(30) @map("session_timeout_seconds")
  offHoursPendingTimeout Int                   @default(10) @map("off_hours_pending_timeout")
  workHoursStart         Int?                  @map("work_hours_start")
  workHoursEnd           Int?                  @map("work_hours_end")
  defaultPersona         String?               @map("default_persona")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  channelConfigs         TenantChannelConfig[]
  staff                  TenantStaff[]

  @@map("tenants")
}

model TenantChannelConfig {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  inboxId         String   @map("inbox_id")
  channelType     String   @map("channel_type")
  name            String
  knowledgeFilter String[] @map("knowledge_filter")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, inboxId])
  @@map("tenant_channel_configs")
}

model TenantStaff {
  id                    String         @id @default(uuid())
  tenantId              String         @map("tenant_id")
  name                  String
  telegramId            String         @map("telegram_id")
  telegramChatId        String         @map("telegram_chat_id")
  isActive              Boolean        @default(true) @map("is_active")
  isOnDuty              Boolean        @default(false) @map("is_on_duty")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  assignedConversations Conversation[] @relation("TenantStaffAssignments")
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, telegramId])
  @@map("tenant_staff")
}

model HandoffEvent {
  id             String   @id @default(uuid())
  tenantId       String?  @map("tenant_id")
  conversationId String   @map("conversation_id")
  staffId        String?  @map("staff_id")
  staffName      String?  @map("staff_name")
  customerName   String?  @map("customer_name")
  customerId     String   @map("customer_id")
  eventType      String   @map("event_type")
  durationMs     Int?     @map("duration_ms")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
  @@index([staffId])
  @@index([conversationId])
  @@map("handoff_events")
}
