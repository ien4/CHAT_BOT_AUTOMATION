# Server
PORT=3001
NODE_ENV=production
# URL công khai của server (domain + HTTPS), dùng cho Facebook webhook
APP_BASE_URL=https://your-domain.com
# URL dashboard/frontend công khai, dùng cho link trong thông báo Telegram
DASHBOARD_URL=https://your-dashboard-domain.com
FRONTEND_URL=

# Encryption key cho tenant credentials (AES-256-GCM, 64 hex chars)
# Tạo key mới: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Database - production/Docker Compose thường trỏ đến service "postgres" trong internal network.
# Local pgvector hiện dùng host port 5433 nếu chạy container bbotech-pgvector-local:
# DATABASE_URL=postgresql://admin:POSTGRES_PASSWORD@localhost:5433/chatbot
DATABASE_URL=postgresql://admin:POSTGRES_PASSWORD@postgres:5432/chatbot

# Facebook Messenger API
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=
FB_APP_SECRET=
FB_PAGE_ID=

# Facebook webhook message rate limit
MESSAGE_RATE_WINDOW_MS=60000
MESSAGE_RATE_MAX=10
MESSAGE_BURST_WINDOW_MS=10000
MESSAGE_BURST_MAX=5
MESSAGE_RATE_BLOCK_MS=120000
MESSAGE_RATE_WARNING_COOLDOWN_MS=60000

# LLM API Keys
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=

# JWT Secret for Dashboard Auth
JWT_SECRET=

# Admin default credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Telegram Bot (Human Handoff)
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
TELEGRAM_STATUS_GROUP_ID=

# Docker Compose: mật khẩu PostgreSQL (cũng khai báo trong file này)
POSTGRES_PASSWORD=
