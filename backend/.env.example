# Server
PORT=3001
NODE_ENV=production
# URL công khai của server (domain + HTTPS) — canonical public base URL, dùng cho
# Facebook webhook và Chatwoot website-chat callback. Callback được DERIVE từ biến này,
# KHÔNG hardcode endpoint key:
#   ${APP_BASE_URL}/integrations/website-chat/<publicEndpointKey>/events
# Candidate (PUBLIC_BASE_URL_CANDIDATE_RECORDED · PUBLIC_CALLBACK_VERIFICATION_PENDING;
# DNS/TLS/reverse-proxy chưa verify, WEBSITE_CHAT_ENABLED=false):
APP_BASE_URL=https://chatbot-test.bboapp.xyz
# URL dashboard/frontend công khai, dùng cho link trong thông báo Telegram
DASHBOARD_URL=https://your-dashboard-domain.com
FRONTEND_URL=

# Encryption key cho tenant credentials (AES-256-GCM, 64 hex chars)
# Tạo key mới: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Database - production/Docker Compose thường trỏ đến service "postgres" trong internal network.
# Local pgvector hiện dùng host port 5433 nếu chạy container bbotech-pgvector-local:
# DATABASE_URL=postgresql://admin:POSTGRES_PASSWORD@localhost:5433/chatbot
DATABASE_URL=postgresql://admin:POSTGRES_PASSWORD@postgres:5432/chatbot

# Facebook Messenger API
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=
FB_APP_SECRET=
FB_PAGE_ID=

# Facebook canonical durable ingress runtime mode: off | shadow | enforce (default off)
FACEBOOK_CANONICAL_RUNTIME_MODE=off

# Chatwoot Account Webhook ingress feature flag (default off). Must be exactly
# 'true' to enable the /integrations/website-chat/:endpointKey/events route.
# Runtime activation still requires exact Chatwoot version, rotated signing secret,
# an enabled ProviderWebhookEndpoint + TenantIntegration, and a wired AI/outbound
# port — none of which this flag alone provides.
WEBSITE_CHAT_ENABLED=false
# Optional receiver policy knobs (non-secret). Left blank → module defaults.
WEBSITE_CHAT_MAX_CLOCK_SKEW_SECONDS=
WEBSITE_CHAT_REPLAY_RETENTION_SECONDS=

# Facebook webhook message rate limit
MESSAGE_RATE_WINDOW_MS=60000
MESSAGE_RATE_MAX=10
MESSAGE_BURST_WINDOW_MS=10000
MESSAGE_BURST_MAX=5
MESSAGE_RATE_BLOCK_MS=120000
MESSAGE_RATE_WARNING_COOLDOWN_MS=60000

# LLM API Keys
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=

# JWT Secret for Dashboard Auth
JWT_SECRET=

# Admin default credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Telegram Bot (Human Handoff)
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
TELEGRAM_STATUS_GROUP_ID=

# Docker Compose: mật khẩu PostgreSQL (cũng khai báo trong file này)
POSTGRES_PASSWORD=
