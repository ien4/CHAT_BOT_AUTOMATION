# Dashboard public configuration
# These values are bundled into the browser build. Do not put secrets here.

# Backend API base URL. Local fallback in src/lib/config/env.ts is http://localhost:3001/api.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Optional Chatwoot UI base URL displayed in Dashboard settings.
NEXT_PUBLIC_CHATWOOT_URL=http://localhost:3000
